{
    "include": [
        "./src/**/*"
    ],
    "compilerOptions": {
        "target": "ES2017",  // ✅ UBAH dari es2015 ke ES2017
        "lib": ["dom", "dom.iterable", "ES2017"],  // ✅ UBAH dari es2015 ke ES2017
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "react-jsx",
        "incremental": true
    }
}